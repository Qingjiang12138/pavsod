<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.pavsod.pavsodbackend.mapper.OriginalVideoMapper">
    <select id="selectVideoById" resultType="com.pavsod.pavsodbackend.entity.Original_video">
        select * from original_video
        <where>
            video_id = #{originalVideoId}
        </where>
    </select>
</mapper>